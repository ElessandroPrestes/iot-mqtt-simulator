# ============================================
# MQTT BROKER
# ============================================
MQTT_BROKER_HOST=broker
MQTT_BROKER_PORT=1883
MQTT_USERNAME=iotuser
MQTT_PASSWORD=iotpassword
MQTT_CLIENT_ID_API=api-processor
MQTT_CLIENT_ID_SIM=simulator

# MQTT Topics
MQTT_TOPIC_PREFIX=factory/sensors
MQTT_TOPIC_TEMPERATURE=factory/sensors/temperature/+
MQTT_TOPIC_PRESSURE=factory/sensors/pressure/+
MQTT_TOPIC_HUMIDITY=factory/sensors/humidity/+
MQTT_TOPIC_VIBRATION=factory/sensors/vibration/+

# ============================================
# DATABASE
# ============================================
MONGODB_URI=mongodb://mongo:27017/iot_dashboard
MONGODB_DB_NAME=iot_dashboard

# ============================================
# API SERVICE
# ============================================
NODE_ENV=development
API_PORT=3000
API_HOST=0.0.0.0
API_VERSION=v1
CORS_ORIGINS=http://localhost:5173,http://localhost:80

# ============================================
# ALERTAS — Thresholds dos sensores
# ============================================
TEMP_WARN_THRESHOLD=70
TEMP_CRITICAL_THRESHOLD=90
PRESSURE_WARN_THRESHOLD=8.5
PRESSURE_CRITICAL_THRESHOLD=10
HUMIDITY_WARN_THRESHOLD=80
HUMIDITY_CRITICAL_THRESHOLD=90
VIBRATION_WARN_THRESHOLD=4.5
VIBRATION_CRITICAL_THRESHOLD=6.0

# ============================================
# OBSERVABILIDADE
# ============================================
LOG_LEVEL=info
LOG_FORMAT=json
METRICS_ENABLED=true
METRICS_PORT=9090

# ============================================
# SIMULATOR
# ============================================
SIMULATOR_INTERVAL_MS=2000
SIMULATOR_SENSORS_COUNT=8
SIMULATOR_ANOMALY_PROBABILITY=0.05

# ============================================
# DASHBOARD (Vite)
# ============================================
VITE_API_URL=http://localhost:3000/api/v1
VITE_WS_URL=http://localhost:3000
VITE_REFRESH_INTERVAL=5000

# ============================================
# AWS IoT Core (apenas produção)
# ============================================
AWS_IOT_ENDPOINT=
AWS_IOT_CERT_PATH=/certs/certificate.pem.crt
AWS_IOT_KEY_PATH=/certs/private.pem.key
AWS_IOT_CA_PATH=/certs/AmazonRootCA1.pem
AWS_REGION=us-east-1
