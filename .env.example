# Copie para .env somente em desenvolvimento. Em produção, use Docker secrets.

# Ambiente e exposição
NODE_ENV=development
API_PORT=3000
API_HOST=0.0.0.0
PUBLIC_ORIGIN=https://localhost:8443
CORS_ORIGINS=http://localhost:5173,http://localhost:8080
NGINX_HTTP_PORT=8080
NGINX_HTTPS_PORT=8443

# Autenticação da aplicação
JWT_SECRET=
JWT_SECRET_FILE=
JWT_ISSUER=iot-mqtt-simulator-api
JWT_AUDIENCE=iot-mqtt-simulator-dashboard
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=28800
SESSION_IDLE_TTL_SECONDS=1800
MAX_CONCURRENT_SESSIONS=3
LOGIN_RATE_WINDOW_MS=900000
LOGIN_RATE_MAX=5
MFA_REQUIRED=false
AUTH_PRINCIPALS_JSON=
AUTH_PRINCIPALS_FILE=
SWAGGER_ENABLED=true

# Identidade interna — obrigatória apenas no perfil de produção
SECRETS_DIR=
INTERNAL_CA_FILE=
API_CLIENT_CERT_FILE=
API_CLIENT_KEY_FILE=
API_TLS_CERT_FILE=
API_TLS_KEY_FILE=
SIMULATOR_CLIENT_CERT_FILE=
SIMULATOR_CLIENT_KEY_FILE=

# MQTT — preencha valores locais; nunca use estas lacunas em produção
MQTT_BROKER_HOST=broker
MQTT_BROKER_PORT=1883
MQTT_USERNAME=
MQTT_PASSWORD=
MQTT_USERNAME_FILE=
MQTT_PASSWORD_FILE=
MQTT_CLIENT_ID_API=api-processor
MQTT_CLIENT_ID_SIM=simulator

# MongoDB — desenvolvimento sem autenticação, isolado na máquina local
MONGODB_URI=mongodb://mongo:27017/iot_dashboard
MONGODB_URI_FILE=
MONGODB_DB_NAME=iot_dashboard

# Alertas
TEMP_WARN_THRESHOLD=70
TEMP_CRITICAL_THRESHOLD=90
PRESSURE_WARN_THRESHOLD=8.5
PRESSURE_CRITICAL_THRESHOLD=10
HUMIDITY_WARN_THRESHOLD=80
HUMIDITY_CRITICAL_THRESHOLD=90
VIBRATION_WARN_THRESHOLD=4.5
VIBRATION_CRITICAL_THRESHOLD=6.0

# Observabilidade
LOG_LEVEL=info
LOG_FORMAT=json
LOG_FILE=
METRICS_ENABLED=true

# Simulador
SIMULATOR_INTERVAL_MS=2000
SIMULATOR_SENSORS_COUNT=8
SIMULATOR_ANOMALY_PROBABILITY=0.05

# Dashboard — URLs relativas mantêm API e WebSocket na mesma origem
VITE_API_URL=/api/v1
VITE_WS_URL=
VITE_REFRESH_INTERVAL=5000

# AWS IoT Core opcional
AWS_IOT_ENDPOINT=
AWS_IOT_CERT_PATH=/certs/certificate.pem.crt
AWS_IOT_KEY_PATH=/certs/private.pem.key
AWS_IOT_CA_PATH=/certs/AmazonRootCA1.pem
AWS_REGION=us-east-1
